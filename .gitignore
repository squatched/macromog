# Macromog .gitignore

# Windower / FFXI specific
data/settings.xml
data/*.log
*.dat
*.dmp

# Common temp / backup files
*.bak
*.tmp
*~
*.swp
*.swo

# OS junk
.DS_Store
Thumbs.db

# Lua / editor files
*.lua~
luac.out

# Coverage artifacts
luacov.stats.out
luacov.report.out
coverage-plugin.xml
coverage-cli.out

# Go build outputs
macromog
*.exe
*.exe~
*.dll
*.so
*.dylib

# Go test binaries (built with go test -c)
*.test

# Go workspace files (local developer overrides, not committed)
go.work
go.work.sum

# Dependency vendoring (not used — modules handle deps)
# vendor/

# Dependencies (if any are downloaded)
libs/*/
!libs/README.md

# Personal / local config
*.user
*.local

# Logs and caches
*.log
.cache/

# Build / packaged outputs (if you ever zip releases)
*.zip
*.tar.gz

# Personal YAML backups (optional - you may want to commit some examples)
# backups/
# data/*.yml
